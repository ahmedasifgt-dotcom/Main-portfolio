<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prayer Time - Project 2</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Google Fonts (Poppins & Hind Siliguri for Bengali) -->
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', 'Hind Siliguri', sans-serif;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-900 via-blue-700 to-sky-400 min-h-screen text-white flex flex-col justify-between">

    <!-- Header Navigation -->
    <header class="p-5 flex justify-between items-center max-w-6xl mx-auto w-full">
        <a href="index.html" class="flex items-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md px-4 py-2 rounded-full border border-white/20 transition-all text-sm font-semibold">
            ← মেইন পোর্টফোলিও (Home)
        </a>
        <span class="text-xs md:text-sm bg-blue-950/40 px-4 py-2 rounded-full border border-white/10">Project 2: Prayer Time</span>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center justify-center px-4 py-8 max-w-4xl mx-auto w-full">
        
        <!-- Greeting & Title Section -->
        <div class="text-center mb-8">
            <h1 id="greeting" class="text-xl md:text-2xl font-light text-sky-200 mb-2">আসসালামু-আলাইকুম, রাইয়াত!</h1>
            <h2 class="text-4xl md:text-5xl font-bold tracking-wide drop-shadow-md">নামাজের সময়সূচী</h2>
            <p class="text-sm text-sky-100/80 mt-2" id="current-date"></p>
        </div>

        <!-- Location Selector -->
        <div class="mb-8 w-full max-w-xs">
            <label for="city-select" class="block text-center text-sm font-medium text-sky-100 mb-2">আপনার শহর পরিবর্তন করুন:</label>
            <select id="city-select" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-sky-300 backdrop-blur-md cursor-pointer">
                <option value="Dhaka" class="text-blue-950" selected>ঢাকা (Dhaka)</option>
                <option value="Chittagong" class="text-blue-950">চট্টগ্রাম (Chittagong)</option>
                <option value="Sylhet" class="text-blue-950">সিলেট (Sylhet)</option>
                <option value="Rajshahi" class="text-blue-950">রাজশাহী (Rajshahi)</option>
                <option value="Khulna" class="text-blue-950">খুলনা (Khulna)</option>
                <option value="Barisal" class="text-blue-950">বরিশাল (Barisal)</option>
                <option value="Rangpur" class="text-blue-950">রংপুর (Rangpur)</option>
                <option value="Mymensingh" class="text-blue-950">ময়মনসিংহ (Mymensingh)</option>
            </select>
        </div>

        <!-- Prayer Times Grid -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 w-full" id="prayer-cards">
            <!-- Cards will be dynamically injected via JS -->
            <div class="animate-pulse bg-white/5 h-32 rounded-2xl col-span-2 md:col-span-5 flex items-center justify-center">লোড হচ্ছে...</div>
        </div>

    </main>

    <!-- Footer -->
    <footer class="text-center p-5 text-xs text-sky-200/50">
        &copy; 2026 রাইয়াত | সর্বস্বত্ব সংরক্ষিত।
    </footer>

    <!-- JavaScript Execution -->
    <script>
        // 1. Time-based Greeting for Rayat
        function setTimeGreeting() {
            const hour = new Date().getHours();
            let greetingStr = "আসসালামু-আলাইকুম, রাইয়াত!";
            
            if (hour >= 5 && hour < 12) {
                greetingStr = "শুভ সকাল, রাইয়াত! আপনার দিনটি বরকতময় হোক।";
            } else if (hour >= 12 && hour < 16) {
                greetingStr = "শুভ দুপুর, রাইয়াত!";
            } else if (hour >= 16 && hour < 18) {
                greetingStr = "শুভ বিকেল, রাইয়াত!";
            } else if (hour >= 18 && hour < 20) {
                greetingStr = "শুভ সন্ধ্যা, রাইয়াত!";
            } else {
                greetingStr = "শুভ রাত্রি, রাইয়াত!";
            }
            document.getElementById('greeting').innerText = greetingStr;
            
            // Set Human Readable Date
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('current-date').innerText = new Date().toLocaleDateString('bn-BD', options);
        }

        // Names translation dictionary
        const prayerNamesBn = {
            Fajr: "ফজর",
            Dhuhr: "যোহর",
            Asr: "আসর",
            Maghrib: "মাগরিব",
            Isha: "এশা"
        };

        // 2. Fetch Prayer Times from API
        async function fetchPrayerTimes(city) {
            const cardsContainer = document.getElementById('prayer-cards');
            cardsContainer.innerHTML = `<div class="text-center w-full col-span-full py-4 text-sky-200">সময়সূচী আপডেট করা হচ্ছে...</div>`;
            
            try {
                const response = await fetch(`https://api.aladhan.com/v1/timingsByCity?city=${city}&country=Bangladesh&method=2`);
                const data = await response.json();
                
                if(data.code === 200) {
                    const timings = data.data.timings;
                    const targetedPrayers = ['Fajr', 'Dhuhr', 'Asr', 'Maghrib', 'Isha'];
                    
                    cardsContainer.innerHTML = ''; // Clear container

                    targetedPrayers.forEach(prayer => {
                        // Formating Time 24h to 12h representation smoothly
                        let [hour, minute] = timings[prayer].split(':');
                        let ampm = hour >= 12 ? 'PM' : 'AM';
                        hour = hour % 12 || 12;
                        let timeStr = `${hour}:${minute} ${ampm}`;

                        cardsContainer.innerHTML += `
                            <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-5 text-center shadow-lg hover:scale-105 transition-all duration-300">
                                <h3 class="text-lg font-bold text-sky-200 mb-1">${prayerNamesBn[prayer]}</h3>
                                <p class="text-2xl font-semibold tracking-wider">${timeStr}</p>
                            </div>
                        `;
                    });
                } else {
                    cardsContainer.innerHTML = `<div class="text-center w-full col-span-full text-red-300">ডাটা লোড করতে ব্যর্থ হয়েছে।</div>`;
                }
            } catch (error) {
                cardsContainer.innerHTML = `<div class="text-center w-full col-span-full text-red-300">নেটওয়ার্ক সমস্যা! আবার চেষ্টা করুন।</div>`;
            }
        }

        // 3. Event Listeners
        document.getElementById('city-select').addEventListener('change', (e) => {
            fetchPrayerTimes(e.target.value);
        });

        // Initial Run
        setTimeGreeting();
        fetchPrayerTimes('Dhaka');
    </script>
</body>
</html>
